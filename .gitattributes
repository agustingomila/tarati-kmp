# Normalización de fin de línea — evita que core.autocrlf=true (Windows) rompa
# scripts que se ejecutan en Linux/Docker (gradlew, *.sh).
#
# Sin esto, en un clon Windows con autocrlf=true el working tree recibe CRLF y
# el build Docker (sh ./gradlew dentro de Alpine) falla con "line 2: : not found".

# Por defecto: git decide el tipo de cada archivo y normaliza a LF en el repo.
* text=auto

# ── Scripts que SIEMPRE deben ser LF (corren en Linux/Docker/VPS) ────────────
gradlew      text eol=lf
*.sh         text eol=lf

# ── Scripts de Windows: SIEMPRE CRLF ─────────────────────────────────────────
gradlew.bat  text eol=crlf
*.bat        text eol=crlf
*.cmd        text eol=crlf

# ── Fuentes y recursos de texto: LF ──────────────────────────────────────────
*.kt    text eol=lf
*.kts   text eol=lf
*.java  text eol=lf
*.xml   text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.sql   text eol=lf
*.properties text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.conf  text eol=lf
Dockerfile* text eol=lf

# ── Binarios: nunca tocar ────────────────────────────────────────────────────
