*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.icns binary
*.jar  binary
*.war  binary
*.keystore binary
*.jks  binary
*.ttf  binary
*.otf  binary
*.woff binary
*.woff2 binary
*.wasm binary
*.mp3  binary
*.wav  binary
*.ogg  binary
*.pdf  binary
*.zip  binary
