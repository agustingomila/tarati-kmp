    <string name="tutorial_introduction_title">Welcome to Tarati</string>
    <string name="tutorial_introduction_description">Tarati is a strategic game of movement and capture. Learn the
        basic rules to start playing.
    </string>
    <string name="tutorial_center_title">The Center</string>
    <string name="tutorial_center_description">Vertex A1 is the Absolute Center, connected to the 6 Bridge vertices
        (B1–B6).
    </string>
    <string name="tutorial_bridge_title">The Bridge</string>
    <string name="tutorial_bridge_description">The 6 Bridge vertices surround the center. They connect the center to
        the outer circumference. Each Bridge vertex has 5 edges.
    </string>
    <string name="tutorial_circumference_title">The Circumference</string>
    <string name="tutorial_circumference_description">12 vertices form the outer ring. Each one connects to its two
        circumference neighbors and to one Bridge vertex.
    </string>
    <string name="tutorial_domestic_bases_title">Home Bases</string>
    <string name="tutorial_domestic_bases_description">Each player has 4 vertices in their home base (2 of type C and
        2 of type D). Pieces start here and can return here.
    </string>
    <string name="tutorial_cobs_title">The Pieces</string>
    <string name="tutorial_cobs_description">Each player starts with 4 Cobs (plain pieces). Cobs can only advance
        toward the enemy base. Once there, they become Roks (marked with an inner circle), which can move in any
        direction.
    </string>
    <string name="tutorial_basic_moves_title">Basic Movement</string>
    <string name="tutorial_basic_moves_description">Cobs move to adjacent empty vertices, advancing toward the enemy
        base only. Exception: from their own home base, a Cob may move in any direction, but only to make a capture.
    </string>
    <string name="tutorial_captures_title">Capturing Pieces</string>
    <string name="tutorial_captures_description">When you move to a vertex, every enemy piece adjacent to your
        destination switches to your color. Multiple pieces can be captured in a single move. Pieces are never
        removed — they change sides.
    </string>
    <string name="tutorial_pre_adjacency_title">The Pre-Adjacency Rule</string>
    <string name="tutorial_pre_adjacency_description">You can only capture an enemy piece if your piece was NOT
        adjacent to it before the move. You must approach from outside. This is the most important tactical rule in
        the game.
    </string>
    <string name="tutorial_upgrade_title">Promotion to Rok</string>
    <string name="tutorial_upgrade_description">A Cob that reaches the enemy home base becomes a Rok. Roks move in
        any direction and keep their rank even if captured and switched to the other color.
    </string>
    <string name="tutorial_dead_piece_title">Dead Pieces</string>
    <string name="tutorial_dead_piece_description">A Cob is dead if it sits on the outermost enemy base vertices
        (D3/D4 for White), or if all its exits are blocked by other dead friendly Cobs. If you have no other moves,
        you may promote a dead Cob to a Rok in place.
    </string>
    <string name="tutorial_domestic_capture_title">Capturing in Your Own Base</string>
    <string name="tutorial_domestic_capture_description">A Cob on its own home base can also move sideways or backward
        to capture an enemy piece already inside your base. The destination must be empty, and the pre-adjacency rule
        still applies: you can only capture a piece you were not already adjacent to.
    </string>
    <string name="tutorial_end_conditions_title">How the Game Ends</string>
    <string name="tutorial_end_conditions_description">You win by Mit: the last enemy piece switches to your color.
        Or by Stalemit: your opponent has no legal moves left. If your opponent causes the same position three times,
        you win as well.
    </string>
    <string name="perform_the_indicated_move">%1$s\n\nMake the indicated move.</string>
    <string name="tutorial_completed_title">Tutorial Complete</string>
    <string name="tutorial_completed_description">You have completed the basic Tarati tutorial. Now try playing a
        game!
    </string>
